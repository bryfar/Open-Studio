{
  "directories": {
    "output": "dist/linux"
  },
  "extraResources": [
    {
      "from": "build/web-export",
      "to": "web-out",
      "filter": ["**/*"]
    }
  ],
  "linux": {
    "artifactName": "OpenStudio-${version}-${arch}.${ext}",
    "executableName": "openstudio-desktop",
    "target": [
      {
        "target": "AppImage",
        "arch": [
          "x64"
        ]
      },
      {
        "target": "deb",
        "arch": [
          "x64"
        ]
      }
    ],
    "category": "AudioVideo"
  }
}
