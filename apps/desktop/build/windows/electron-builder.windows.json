{
  "directories": {
    "output": "dist/windows"
  },
  "extraResources": [
    {
      "from": "build/web-export",
      "to": "web-out",
      "filter": ["**/*"]
    }
  ],
  "win": {
    "signAndEditExecutable": false,
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
