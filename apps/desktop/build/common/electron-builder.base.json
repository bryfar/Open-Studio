{
  "appId": "com.openstudio.desktop",
  "productName": "Open Studio",
  "icon": "build/icon.png",
  "directories": {
    "output": "dist/common"
  },
  "files": [
    "main.cjs",
    "preload.cjs"
  ],
  "extraResources": [
    {
      "from": "build/web-export",
      "to": "web-out",
      "filter": [
        "**/*"
      ]
    }
  ],
  "publish": [
    {
      "provider": "github",
      "owner": "bryfar",
      "repo": "Open-Studio",
      "releaseType": "release"
    }
  ]
}
