{
  "directories": {
    "output": "dist/macos"
  },
  "extraResources": [
    {
      "from": "build/web-export",
      "to": "web-out",
      "filter": ["**/*"]
    }
  ],
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": [
          "x64",
          "arm64"
        ]
      }
    ],
    "category": "public.app-category.video"
  }
}
