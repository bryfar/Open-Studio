HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Optional provider defaults (can be overridden per request headers)
GEMINI_API_KEY=
FAL_KEY=
ELEVENLABS_API_KEY=
UPLOAD_POST_API_KEY=

# Optional storage / ffmpeg tuning
MAX_UPLOAD_MB=2048
TEMP_DIR=./tmp
ENABLE_FFMPEG=true

# Redis queue
REDIS_URL=redis://localhost:6379/0
RQ_QUEUE_NAME=openshorts

# S3 artifact storage
S3_ENABLED=false
S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=
S3_PUBLIC_BASE_URL=
